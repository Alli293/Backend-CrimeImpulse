# Application Configuration
APP_NAME="CrimePulse"
ENVIRONMENT="development"
LOG_LEVEL="info"

# OpenAI Configuration
OPENAI_API_KEY=""

# Langfuse Observability
# Run Langfuse frontend and get these keys from the Langfuse app by setting a new project
LANGFUSE_SECRET_KEY="edwda"
LANGFUSE_PUBLIC_KEY="adwdaw"
# DNS name of the Langfuse frontend service in the Docker network
LANGFUSE_HOST="http://langfuse-web:3000"

# Alternative GenAI Configuration
GENAI_API_KEY=""
GENAI_BASE_URL="http://172.18.16.1:8080/v1"
GENAI_MODEL="unsloth/Qwen3.5-35B-A3B-GGUF:Q4_K_M"

# CrimePulse SUPABASE
SUPABASE_HOST="https://your-supabase-url"
SUPABASE_PORT="your-supabase-port"
SUPABASE_PASSWORD="your-supabase-password"
SUPABASE_DATABASE="your-supabase-database"
SUPABASE_USER="postgres"

# Langfuse PostgreSQL
LANGFUSE_POSTGRES_USER="langfuse"
LANGFUSE_POSTGRES_PASSWORD="langfuse"
LANGFUSE_POSTGRES_DB="langfuse"
LANGFUSE_DATABASE_URL="postgresql://langfuse:langfuse@langfuse-postgres:5432/langfuse"

# Redis Configuration (shared with Langfuse)
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_DB="0"
REDIS_AUTH="myredissecret"